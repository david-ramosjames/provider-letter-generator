# Anthropic API key — enables AI-based provider extraction (recommended).
# Without it the app falls back to a built-in heuristic parser.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# Supabase — used to pre-fill client name, date of birth, and date of loss
# from the cases table by case_number.
SUPABASE_URL=https://mcczpwrmzemlqfsupquw.supabase.co
# Use the service role key (server-side only) or anon key with read access.
SUPABASE_KEY=
